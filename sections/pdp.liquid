    { "type": "select", "id": "thumb_position", "label": "Thumbnail flow", "options": [ { "value": "below-scroll", "label": "Below (scrollable row)" }, { "value": "below-wrap", "label": "Below (wrapping grid)" } ], "default": "below-scroll" },
    { "type": "range", "id": "thumb_size", "min": 56, "max": 120, "step": 4, "unit": "px", "label": "Thumbnail size", "default": 76 },
    { "type": "select", "id": "image_ratio", "label": "Image aspect ratio", "options": [ { "value": "1/1", "label": "Square (1:1)" }, { "value": "4/5", "label": "Portrait (4:5)" }, { "value": "3/4", "label": "Portrait (3:4)" }, { "value": "4/3", "label": "Landscape (4:3)" }, { "value": "auto", "label": "Natural" } ], "default": "1/1" },

