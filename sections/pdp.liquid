    { "type": "select", "id": "media_position", "label": "Media position", "options": [ { "value": "left", "label": "Left" }, { "value": "right", "label": "Right" } ], "default": "left" },
    { "type": "range", "id": "column_gap", "min": 16, "max": 96, "step": 4, "unit": "px", "label": "Column gap", "default": 48 },
    { "type": "checkbox", "id": "sticky_media", "label": "Sticky media on desktop", "default": true },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 48 },

    { "type": "header", "content": "Gallery" },
