{{ 'glowmist-landing.css' | asset_url | stylesheet_tag }}

<section class="glowmist-section" id="glowmist-reviews">
  <div class="glowmist-container">
    <div class="glowmist-heading">
      <p>{{ section.settings.kicker }}</p>
      <h2>{{ section.settings.heading }}</h2>
    </div>

    <div class="glowmist-reviews">
      {% for block in section.blocks %}
        <article class="glowmist-review" {{ block.shopify_attributes }}>
          <div class="glowmist-review-top">
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 120
                | image_tag: widths: '80, 120', sizes: '48px', loading: 'lazy', alt: block.settings.name
              }}
            {% else %}
              <span>{{ block.settings.name | slice: 0 }}</span>
            {% endif %}
            <div>
              <h3>{{ block.settings.name }}</h3>
              <p aria-label="{{ block.settings.rating }} out of 5 stars">
                {% for index in (1..5) %}
                  {% if index <= block.settings.rating %}★{% else %}☆{% endif %}
                {% endfor %}
              </p>
            </div>
          </div>
          <blockquote>{{ block.settings.text }}</blockquote>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "GlowMist reviews",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Customer love" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Daily glow, reviewed" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Customer image" },
        { "type": "text", "id": "name", "label": "Customer name", "default": "Ananya S." },
        { "type": "range", "id": "rating", "label": "Rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea", "id": "text", "label": "Review text", "default": "My skin feels instantly refreshed and glowy." }
      ]
    }
  ],
  "presets": [
    {
      "name": "GlowMist reviews",
      "blocks": [
        { "type": "review", "settings": { "name": "Ananya S.", "rating": 5, "text": "My skin feels fresh after one spray. I keep it on my work desk and use it before video calls." } },
        { "type": "review", "settings": { "name": "Meera K.", "rating": 5, "text": "The mist is fine, not sticky, and works beautifully over makeup." } },
        { "type": "review", "settings": { "name": "Riya P.", "rating": 4, "text": "Lightweight and calming. The Buy 2, Get 1 offer is perfect because I use it daily." } }
      ]
    }
  ]
}
{% endschema %}
