{{ 'glowmist-landing.css' | asset_url | stylesheet_tag }}
<script src="{{ 'glowmist-landing.js' | asset_url }}" defer="defer"></script>

{% liquid
  assign product = section.settings.product
  assign selected_variant = product.selected_or_first_available_variant
  assign product_title = section.settings.product_name
  assign product_price = section.settings.price_text
  assign has_compare_price = false
  assign show_scarcity = false
  assign slide_count = 0

  if product != blank
    assign product_title = product.title
    assign product_price = selected_variant.price | money
  endif

  if selected_variant != blank and selected_variant.compare_at_price > selected_variant.price
    assign has_compare_price = true
    assign savings_pct = selected_variant.compare_at_price | minus: selected_variant.price | times: 100 | divided_by: selected_variant.compare_at_price
  endif

  if selected_variant != blank
    if selected_variant.inventory_management == 'shopify' and selected_variant.inventory_quantity > 0 and selected_variant.inventory_quantity <= 15
      assign show_scarcity = true
    endif
  endif

  for block in section.blocks
    if block.type == 'hero_slide'
      assign slide_count = slide_count | plus: 1
    endif
  endfor
%}

<section
  class="glowmist-section"
  style="--gm-blush: {{ section.settings.color_blush }}; --gm-berry: {{ section.settings.color_berry }}; --gm-ink: {{ section.settings.color_ink }}; --gm-muted: {{ section.settings.color_muted }}; --gm-cream: {{ section.settings.color_cream }};"
>
  <div class="glowmist-announcement">{{ section.settings.announcement_text }}</div>

  <div class="glowmist-container glowmist-hero" data-glowmist-hero>
    <div class="glowmist-hero-content">
      <p class="glowmist-eyebrow">{{ section.settings.eyebrow }}</p>
      <h1>{{ section.settings.headline }}</h1>
      <p class="glowmist-subheadline">{{ section.settings.subheadline }}</p>

      <div class="glowmist-social-proof">
        <div class="glowmist-stars" aria-label="4.8 out of 5 stars" role="img">
          {% for index in (1..5) %}
            <span aria-hidden="true">★</span>
          {% endfor %}
        </div>
        <span class="glowmist-rating-score">4.8/5</span>
        <span class="glowmist-rating-count">{{ section.settings.review_count }}</span>
        <span class="glowmist-proof-divider">·</span>
        <span class="glowmist-customers">{{ section.settings.customer_count }}</span>
      </div>

      <div class="glowmist-card glowmist-purchase" data-glowmist-cart>
        <div>
          <p class="glowmist-product-name">{{ product_title }}</p>
          <div class="glowmist-price-row">
            <span class="glowmist-price" data-glowmist-price>{{ product_price }}</span>
            {% if has_compare_price %}
              <span class="glowmist-compare-price">{{ selected_variant.compare_at_price | money }}</span>
              <span class="glowmist-savings-badge">{{ savings_pct }}% OFF</span>
            {% endif %}
          </div>
          <span class="glowmist-offer">{{ section.settings.offer_text }}</span>
        </div>

        <div class="glowmist-urgency-strip">
          {% if product == blank or selected_variant.available %}
            <span class="glowmist-stock-dot glowmist-stock-dot--green" aria-hidden="true"></span>
            <span>In Stock</span>
            <span class="glowmist-urgency-divider" aria-hidden="true">·</span>
            <span>Ships Today</span>
            <span class="glowmist-urgency-divider" aria-hidden="true">·</span>
            <span>{{ section.settings.sold_count }} sold in last 24h</span>
          {% else %}
            <span class="glowmist-stock-dot glowmist-stock-dot--red" aria-hidden="true"></span>
            <span>Out of Stock</span>
          {% endif %}
        </div>

        {% if show_scarcity %}
          <p class="glowmist-scarcity" role="alert">Only {{ selected_variant.inventory_quantity }} left - selling fast</p>
        {% endif %}

        {% if product != blank and product.variants.size > 1 %}
          <label class="glowmist-field">
            <span>Variant</span>
            <select data-glowmist-variant>
              {% for variant in product.variants %}
                <option
                  value="{{ variant.id }}"
                  data-price="{{ variant.price | money }}"
                  {% unless variant.available %}disabled{% endunless %}
                  {% if variant.id == selected_variant.id %}selected{% endif %}
                >
                  {{ variant.title }}{% unless variant.available %} - Sold out{% endunless %}
                </option>
              {% endfor %}
            </select>
          </label>
        {% elsif selected_variant != blank %}
          <input type="hidden" data-glowmist-variant value="{{ selected_variant.id }}">
        {% endif %}

        <div class="glowmist-actions">
          <label class="glowmist-quantity">
            <span>Qty</span>
            <input data-glowmist-quantity type="number" min="1" value="1" inputmode="numeric">
          </label>
          <button
            class="glowmist-button"
            type="button"
            data-glowmist-add
            {% if product != blank and selected_variant.available == false %}disabled{% endif %}
          >
            <span data-glowmist-add-label>{{ section.settings.cta_text }}</span>
          </button>
        </div>
        <p class="glowmist-message" data-glowmist-message role="status" aria-live="polite"></p>

        <div class="glowmist-guarantee-strip">
          <span>Secure Checkout</span>
          <span>{{ section.settings.guarantee_text }}</span>
          <span>Free Prepaid Shipping</span>
        </div>
      </div>

      <div class="glowmist-secondary-actions">
        <a href="#glowmist-ingredients">View Ingredients</a>
        <a href="#glowmist-reviews">See Reviews</a>
      </div>
    </div>

    <div class="glowmist-hero-media">
      <div class="glowmist-benefit-chip glowmist-benefit-chip--tl" aria-hidden="true">
        <span class="glowmist-benefit-chip__icon">+</span>
        <span>Instant Hydration</span>
      </div>
      <div class="glowmist-benefit-chip glowmist-benefit-chip--tr" aria-hidden="true">
        <span class="glowmist-benefit-chip__icon">+</span>
        <span>Natural Ingredients</span>
      </div>
      <div class="glowmist-benefit-chip glowmist-benefit-chip--bl" aria-hidden="true">
        <span class="glowmist-benefit-chip__icon">+</span>
        <span>Alcohol-Free</span>
      </div>
      <div class="glowmist-benefit-chip glowmist-benefit-chip--br" aria-hidden="true">
        <span class="glowmist-benefit-chip__icon">+</span>
        <span>Dermatologist Tested</span>
      </div>

      <div class="glowmist-hero-carousel" data-glowmist-carousel>
        <div class="glowmist-hero-carousel__track" data-glowmist-carousel-track>
          {% if slide_count > 0 %}
            {% assign rendered_slide_count = 0 %}
            {% for block in section.blocks %}
              {% if block.type == 'hero_slide' %}
                {% assign rendered_slide_count = rendered_slide_count | plus: 1 %}
                {% assign slide_loading = 'lazy' %}
                {% if rendered_slide_count == 1 %}
                  {% assign slide_loading = 'eager' %}
                {% endif %}
                {% assign slide_alt = block.settings.alt_text | default: product_title %}
                <div class="glowmist-hero-carousel__slide" data-glowmist-carousel-slide {{ block.shopify_attributes }}>
                  {% if block.settings.image != blank %}
                    {{
                      block.settings.image
                      | image_url: width: 1200
                      | image_tag:
                        widths: '360, 540, 720, 960, 1200',
                        sizes: '(min-width: 990px) 46vw, 92vw',
                        loading: slide_loading,
                        alt: slide_alt
                    }}
                  {% elsif section.settings.hero_image != blank %}
                    {{
                      section.settings.hero_image
                      | image_url: width: 1200
                      | image_tag:
                        widths: '360, 540, 720, 960, 1200',
                        sizes: '(min-width: 990px) 46vw, 92vw',
                        loading: slide_loading,
                        alt: slide_alt
                    }}
                  {% else %}
                    <img src="{{ 'glowmist-product.png' | asset_url }}" alt="{{ block.settings.alt_text | default: product_title | escape }}" width="1200" height="1200" loading="{{ slide_loading }}">
                  {% endif %}

                  {% if block.settings.caption != blank %}
                    <p class="glowmist-hero-carousel__caption">{{ block.settings.caption }}</p>
                  {% endif %}
                </div>
              {% endif %}
            {% endfor %}
          {% else %}
            <div class="glowmist-hero-carousel__slide" data-glowmist-carousel-slide>
              {% if section.settings.hero_image != blank %}
                {{
                  section.settings.hero_image
                  | image_url: width: 1200
                  | image_tag:
                    widths: '360, 540, 720, 960, 1200',
                    sizes: '(min-width: 990px) 46vw, 92vw',
                    loading: 'eager',
                    alt: product_title
                }}
              {% else %}
                <img src="{{ 'glowmist-product.png' | asset_url }}" alt="{{ product_title | escape }}" width="1200" height="1200" loading="eager">
              {% endif %}
            </div>
          {% endif %}
        </div>

        {% if slide_count > 1 %}
          <button class="glowmist-carousel-button glowmist-carousel-button--prev" type="button" data-glowmist-carousel-prev aria-label="Previous image">‹</button>
          <button class="glowmist-carousel-button glowmist-carousel-button--next" type="button" data-glowmist-carousel-next aria-label="Next image">›</button>
          <div class="glowmist-carousel-dots" data-glowmist-carousel-dots aria-label="Hero image carousel pagination"></div>
        {% endif %}
      </div>

      <div class="glowmist-mobile-benefits" aria-hidden="true">
        <span class="glowmist-mobile-benefit-tag">Hydrating</span>
        <span class="glowmist-mobile-benefit-tag">Natural</span>
        <span class="glowmist-mobile-benefit-tag">Alcohol-Free</span>
        <span class="glowmist-mobile-benefit-tag">Derm-Tested</span>
      </div>
    </div>
  </div>

  <div class="glowmist-trust">
    {% for block in section.blocks %}
      {% if block.type == 'trust_badge' %}
        <span {{ block.shopify_attributes }}>{{ block.settings.title }}</span>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "GlowMist hero",
  "settings": [
    { "type": "product", "id": "product", "label": "Product" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" },
    { "type": "text", "id": "announcement_text", "label": "Announcement text", "default": "Free shipping on prepaid orders" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "GlowMist Hydrating Face Mist" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "Instant Hydration. Natural Glow. Anytime." },
    { "type": "textarea", "id": "subheadline", "label": "Subheadline", "default": "A premium face mist made for daily hydration, dewy skin, and quick refreshes between skincare steps, meetings, workouts, and travel." },
    { "type": "text", "id": "product_name", "label": "Fallback product name", "default": "GlowMist Hydrating Face Mist" },
    { "type": "text", "id": "price_text", "label": "Fallback price", "default": "₹999" },
    { "type": "text", "id": "offer_text", "label": "Offer badge", "default": "Buy 2, Get 1 Free" },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Add to Cart" },
    { "type": "text", "id": "review_count", "label": "Review count label", "default": "2,400+ reviews" },
    { "type": "text", "id": "customer_count", "label": "Customer count label", "default": "Trusted by 10,000+ customers" },
    { "type": "text", "id": "sold_count", "label": "Sold in last 24h", "default": "43" },
    { "type": "text", "id": "guarantee_text", "label": "Guarantee text", "default": "30-Day Money-Back Guarantee" },
    { "type": "color", "id": "color_blush", "label": "Blush", "default": "#f7c8ce" },
    { "type": "color", "id": "color_berry", "label": "Berry", "default": "#8f3d55" },
    { "type": "color", "id": "color_ink", "label": "Ink", "default": "#33232a" },
    { "type": "color", "id": "color_muted", "label": "Muted text", "default": "#6d5961" },
    { "type": "color", "id": "color_cream", "label": "Cream background", "default": "#fff8f6" }
  ],
  "blocks": [
    {
      "type": "hero_slide",
      "name": "Hero carousel image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "alt_text", "label": "Alt text", "default": "GlowMist Hydrating Face Mist" },
        { "type": "text", "id": "caption", "label": "Caption", "default": "Hydration that goes anywhere" }
      ]
    },
    {
      "type": "trust_badge",
      "name": "Trust badge",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Dermatologically tested" }
      ]
    }
  ],
  "presets": [
    {
      "name": "GlowMist hero",
      "blocks": [
        { "type": "hero_slide", "settings": { "caption": "Instant hydration in a fine mist" } },
        { "type": "hero_slide", "settings": { "caption": "Fresh glow for work, travel, and makeup prep" } },
        { "type": "hero_slide", "settings": { "caption": "Lightweight skincare for daily touch-ups" } },
        { "type": "trust_badge", "settings": { "title": "Dermatologically tested" } },
        { "type": "trust_badge", "settings": { "title": "No sticky residue" } },
        { "type": "trust_badge", "settings": { "title": "Free prepaid shipping" } }
      ]
    }
  ]
}
{% endschema %}
