{{ 'glowmist-landing.css' | asset_url | stylesheet_tag }}
<script src="{{ 'glowmist-landing.js' | asset_url }}" defer="defer"></script>

<section class="glowmist-section glowmist-white" data-glowmist-faq>
  <div class="glowmist-container">
    <div class="glowmist-heading">
      <p>{{ section.settings.kicker }}</p>
      <h2>{{ section.settings.heading }}</h2>
    </div>

    <div class="glowmist-faq-list">
      {% for block in section.blocks %}
        <div class="glowmist-faq-item" data-glowmist-faq-item {{ block.shopify_attributes }}>
          <button class="glowmist-faq-button" data-glowmist-faq-button type="button" aria-expanded="false">
            <span>{{ block.settings.question }}</span>
            <span aria-hidden="true">+</span>
          </button>
          <div class="glowmist-faq-panel" data-glowmist-faq-panel>
            <p>{{ block.settings.answer }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "GlowMist FAQ",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Questions" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Before you mist" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Is it suitable for oily skin?" },
        { "type": "textarea", "id": "answer", "label": "Answer", "default": "Yes. The formula is lightweight and non-sticky." }
      ]
    }
  ],
  "presets": [
    {
      "name": "GlowMist FAQ",
      "blocks": [
        { "type": "faq", "settings": { "question": "Is it suitable for oily skin?", "answer": "Yes. GlowMist is lightweight, non-sticky, and suitable for oily, dry, combination, and normal skin types." } },
        { "type": "faq", "settings": { "question": "Can I use it over makeup?", "answer": "Yes. Hold the bottle 8 to 10 inches away and spray lightly to refresh makeup without disturbing the base." } },
        { "type": "faq", "settings": { "question": "How many times can I use it daily?", "answer": "Use it whenever your skin needs a refresh. Most customers use it 2 to 4 times a day." } },
        { "type": "faq", "settings": { "question": "Is it alcohol-free?", "answer": "The section content is editable. Connect it to the final product formula once the brand confirms the ingredient list." } }
      ]
    }
  ]
}
{% endschema %}
